<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/foreground_fragment_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout

        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.search.SearchFragment">


        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/favorite_option_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="16dp"
            android:layout_marginRight="8dp"
            android:layout_marginLeft="4dp"
            app:layout_constraintStart_toStartOf="parent"
            android:checked="false"
            tools:ignore="UseSwitchCompatOrMaterialXml" />


        <ImageButton
            android:id="@+id/filter_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="28dp"
            android:src="@drawable/baseline_backspace_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@+id/favorite_option_switch"
            android:layout_marginEnd="16dp"
            android:visibility="invisible"/>


        <TextView
            android:id="@+id/favorites_loaded_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginTop="28dp"
            android:layout_marginRight="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/element_count"
            />

        <TextView
            android:id="@+id/element_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="elements"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginTop="28dp"
            android:layout_marginRight="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            />

        <TextView
            android:id="@+id/empty_favorite_song"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Favorites List 가 비어있습니다. 좋아하는 노래를 추가하세요."
            android:textSize="16sp"
            android:layout_marginLeft="10dp"
            app:layout_constraintTop_toBottomOf="@+id/filter_button"
            app:layout_constraintStart_toStartOf="parent"
            android:visibility="visible"
            />

        <TextView
            android:id="@+id/empty_favorite_artist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Favorites List 가 비어있습니다. 좋아하는 아티스트를 추가하세요."
            android:textSize="16sp"
            android:layout_marginLeft="10dp"
            app:layout_constraintTop_toBottomOf="@+id/filter_button"
            app:layout_constraintStart_toStartOf="parent"
            android:visibility="visible"
            />


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/result_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_margin="8dp"
            android:paddingBottom="@dimen/navigation_bar_margin"
            app:layout_constraintTop_toBottomOf="@id/filter_button"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


        <include layout="@layout/include_webview_hidden" />


        <include layout="@layout/include_webview_hidden_2" />




        <TextView
            android:id="@+id/metadata_lyrics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="슬퍼하지마 No No No"
            android:textSize="16sp"
            android:textColor="#666666"
            android:visibility="invisible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
        </TextView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
