<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- data_info: 왼쪽 영역 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/data_info"
        android:layout_width="220dp"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 왼쪽 연도/곡수 정보 섹션 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/period_selection_tab"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            android:orientation="vertical"
            android:layout_margin="8dp"
            app:cardBackgroundColor="#2B2B2B"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="2dp">
                <TextView
                    android:id="@+id/chart_option"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="Last Month"
                    android:padding="4dp"
                    android:layout_weight="1"
                    android:textSize="@dimen/text_size_xsmall"
                    android:textColor="@color/text_white">
                </TextView>

                <ImageButton
                    android:id="@+id/dropdown_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_arrow_drop_down"
                    android:background="@android:color/transparent"
                    app:tint="@color/text_white">
                </ImageButton>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/modify_specific_year_card"
            android:layout_width="54dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:orientation="vertical"
            android:layout_marginTop="9dp"
            android:layout_marginStart="8dp"
            app:cardBackgroundColor="#2B2B2B"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/period_selection_tab">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="2dp">
                <TextView
                    android:id="@+id/modify_specific_year"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="연도선택"
                    android:padding="4dp"
                    android:layout_weight="1"
                    android:textSize="@dimen/text_size_xxsmall"
                    android:textColor="@color/text_white">
                </TextView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/period_selection_tab"
            app:layout_constraintBottom_toBottomOf="parent">
        </androidx.recyclerview.widget.RecyclerView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- LineChart: 오른쪽 영역 -->
    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/line_chart"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="14dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/data_info"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
