<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:id="@+id/info_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- 제목 줄 -->
        <LinearLayout
            android:id="@+id/title_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/track_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="몰라요"
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small"
                android:textStyle="bold"
                android:visibility="visible" />


        </LinearLayout>

        <!-- 아티스트 줄 -->
        <LinearLayout
            android:id="@+id/artist_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="아티스트: "
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small"
                />

            <TextView
                android:id="@+id/artist_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apink"
                android:textColor="@color/text_white"
                android:textIsSelectable="false"
                android:textSize="@dimen/text_size_small"
                android:textStyle="italic|bold" />
        </LinearLayout>

        <!-- 앨범 줄 -->
        <LinearLayout
            android:id="@+id/album_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="앨범: "
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small" />

            <TextView
                android:id="@+id/album_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOOK"
                android:textColor="@color/text_white"
                android:textIsSelectable="false"
                android:textSize="@dimen/text_size_small"
                android:textStyle="italic|bold" />
        </LinearLayout>

        <!-- 보컬 -->
        <LinearLayout
            android:id="@+id/vocalists_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="보컬: "
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small" />

            <TextView
                android:id="@+id/vocalists"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="정은지, 김남주, 윤보미, 박초롱, 손나은, 오하영"
                android:textIsSelectable="false"
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small"
                android:textStyle="italic" />
        </LinearLayout>

        <!-- 작사 -->
        <LinearLayout
            android:id="@+id/lyricists_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="작사: "
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small" />

            <TextView
                android:id="@+id/lyricists"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="이단옆차기, 데이데이(Dayday), 박장근, 챈슬러"
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small" />
        </LinearLayout>

        <!-- 작곡 -->
        <LinearLayout
            android:id="@+id/composers_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="작곡: "
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small"/>

            <TextView
                android:id="@+id/composers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="이단옆차기, SEION, 박장근, 챈슬러"
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small" />
        </LinearLayout>

        <!-- 발매일 -->
        <LinearLayout
            android:id="@+id/release_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="발매일: "
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small"/>

            <TextView
                android:id="@+id/release_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2020-04-13"
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small"/>

            <LinearLayout
                android:layout_gravity="center"
                android:id="@+id/days_between_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  (d + "
                    android:textColor="@color/text_white"
                    android:textSize="12dp" />

                <TextView
                    android:id="@+id/days_between"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="null"
                    android:textColor="@color/text_white"
                    android:textSize="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=")"
                    android:textColor="@color/text_white"
                    android:textSize="12dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 재생시간 -->
        <LinearLayout
            android:id="@+id/duration_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="재생시간: "
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small"/>

            <TextView
                android:id="@+id/duration_ms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3분 28초"
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small" />
        </LinearLayout>

        <!-- 추가 날짜 -->
        <LinearLayout
            android:id="@+id/added_date_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="추가한 날짜: "
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small" />

            <TextView
                android:id="@+id/added_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2025-06-29"
                android:textColor="@color/text_white"
                android:textSize="@dimen/text_size_small" />
        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>