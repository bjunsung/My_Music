<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginBottom="@dimen/navigation_bar_margin">

    <!-- 📌 메인 화면 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 🔹 왼쪽 사이드 패널 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_side_panel"
            android:layout_width="60dp"
            android:layout_height="0dp"
            android:layout_margin="4dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/background_color_secondary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:id="@+id/side_panel"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical">
                <!-- ☰ 햄버거 버튼 -->
                <ImageButton
                    android:id="@+id/btn_menu"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginLeft="8dp"
                    android:src="@drawable/round_menu_24"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:focusable="false"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/year_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2\n0\n2\n5"
                    android:textColor="@color/basic_soft"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:layout_marginLeft="23dp"
                    android:layout_marginBottom="16dp"
                    />
            </LinearLayout>

                <!-- 메뉴 항목 -->
                <LinearLayout
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="0dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/focused_image_card"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginLeft="12dp"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp">
                        <ImageView
                            android:id="@+id/focused_image"
                            android:layout_width="145dp"
                            android:layout_height="145dp"
                            android:src="@drawable/ic_image_not_found_foreground" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:id="@+id/track_info_content"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="4dp"
                        android:layout_marginLeft="16dp"
                        android:visibility="gone"
                        android:orientation="vertical">

                        <!-- 제목 줄 -->
                        <LinearLayout
                            android:id="@+id/title_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="left"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/track_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="몰라요"
                                android:textSize="@dimen/text_size_small"
                                android:textStyle="bold"
                                android:visibility="visible" />


                        </LinearLayout>

                        <!-- 아티스트 줄 -->
                        <LinearLayout
                            android:id="@+id/artist_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="left"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="아티스트: "
                                android:textSize="@dimen/text_size_small"
                                />

                            <TextView
                                android:id="@+id/artist_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Apink"
                                android:textIsSelectable="false"
                                android:textSize="@dimen/text_size_small"
                                android:textStyle="italic|bold" />
                        </LinearLayout>

                        <!-- 앨범 줄 -->
                        <LinearLayout
                            android:id="@+id/album_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="left"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="앨범: "
                                android:textSize="@dimen/text_size_small" />

                            <TextView
                                android:id="@+id/album_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LOOK"
                                android:textIsSelectable="false"
                                android:textSize="@dimen/text_size_small"
                                android:textStyle="italic|bold" />
                        </LinearLayout>

                        <!-- 보컬 -->
                        <LinearLayout
                            android:id="@+id/vocalists_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:gravity="left"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="보컬: "
                                android:textSize="@dimen/text_size_small" />

                            <TextView
                                android:id="@+id/vocalists"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="정은지, 김남주, 윤보미, 박초롱, 손나은, 오하영"
                                android:textIsSelectable="false"
                                android:textSize="@dimen/text_size_small"
                                android:textStyle="italic" />
                        </LinearLayout>

                        <!-- 작사 -->
                        <LinearLayout
                            android:id="@+id/lyricists_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:gravity="left"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="작사: "
                                android:textSize="@dimen/text_size_small" />

                            <TextView
                                android:id="@+id/lyricists"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="이단옆차기, 데이데이(Dayday), 박장근, 챈슬러"
                                android:textSize="@dimen/text_size_small" />
                        </LinearLayout>

                        <!-- 작곡 -->
                        <LinearLayout
                            android:id="@+id/composers_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:gravity="left"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="작곡: "
                                android:textSize="@dimen/text_size_small"/>

                            <TextView
                                android:id="@+id/composers"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="이단옆차기, SEION, 박장근, 챈슬러"
                                android:textSize="@dimen/text_size_small" />
                        </LinearLayout>

                        <!-- 발매일 -->
                        <LinearLayout
                            android:id="@+id/release_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="left"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="발매일: "
                                android:textSize="@dimen/text_size_small"/>

                            <TextView
                                android:id="@+id/release_date"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2020-04-13"
                                android:textSize="@dimen/text_size_small"/>

                            <!--
                            <LinearLayout
                                android:layout_gravity="center"
                                android:id="@+id/days_between_layout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="  (d + "
                                    android:textSize="12dp" />

                                <TextView
                                    android:id="@+id/days_between"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="null"
                                    android:textSize="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=")"
                                    android:textSize="12dp" />
                            </LinearLayout>
                            -->
                        </LinearLayout>

                        <!-- 재생시간 -->
                        <LinearLayout
                            android:id="@+id/duration_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="left"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="재생시간: "
                                android:textSize="@dimen/text_size_small"/>

                            <TextView
                                android:id="@+id/duration_ms"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3분 28초"
                                android:textSize="@dimen/text_size_small" />
                        </LinearLayout>

                        <!-- 추가 날짜 -->
                        <LinearLayout
                            android:id="@+id/added_date_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:gravity="left"
                            android:visibility="visible">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="추가일: "
                                android:textSize="@dimen/text_size_small" />

                            <TextView
                                android:id="@+id/added_date"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2025-06-29"
                                android:textSize="@dimen/text_size_small" />
                        </LinearLayout>

                    </LinearLayout>
                    <TextView
                        android:id="@+id/move_today_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/basic_soft"
                        android:padding="4dp"
                        android:text="오늘로 이동"
                        android:layout_marginTop="6dp"
                        android:textSize="@dimen/text_size_small"
                        android:visibility="visible"
                        android:layout_marginStart="8dp"/>

                    <TextView
                        android:id="@+id/release_date_chart_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="차트보기"
                        android:padding="4dp"
                        android:layout_marginTop="6dp"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/basic_soft"
                        android:visibility="visible"
                        android:layout_marginStart="8dp"/>

                    <TextView
                        android:id="@+id/play_count_chart_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="playtime"
                        android:padding="4dp"
                        android:layout_marginTop="6dp"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/basic_soft"
                        android:visibility="visible"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- 🔸 월 텍스트 (ex. 7월) -->
        <TextView
            android:id="@+id/month_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUGUST"
            android:textSize="@dimen/text_size_large"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/card_side_panel"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="30dp" />


        <LinearLayout
            android:id="@+id/day_of_week_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="28dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/month_text"
            app:layout_constraintStart_toEndOf="@id/card_side_panel"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="SUN"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_xsmall" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="MON"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_xsmall" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="TUE"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_xsmall" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="WED"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_xsmall" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="THU"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_xsmall" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="FRI"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_xsmall" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="SAT"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_xsmall" />
        </LinearLayout>

        <!-- 🔹 캘린더 뷰 -->



        <!-- 🔹 콘텐츠 프래그먼트 영역 (필요 시) -->
        <com.kizitonwose.calendar.view.CalendarView
            android:id="@+id/calendar_view"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="4dp"
            android:background="@android:color/transparent"
            android:paddingLeft="20dp"
            android:paddingRight="28dp"
            app:cv_dayViewResource="@layout/calendar_day_layout"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.562"
            app:layout_constraintStart_toEndOf="@id/card_side_panel"
            app:layout_constraintTop_toBottomOf="@id/day_of_week_header"
            app:layout_constraintVertical_bias="0.75" />

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/card_side_panel"
            app:layout_constraintEnd_toEndOf="parent"
            android:visibility="gone" />

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.drawerlayout.widget.DrawerLayout>
