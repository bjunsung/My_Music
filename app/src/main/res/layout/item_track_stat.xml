<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/artwork_card"
        android:layout_width="44dp"
        android:layout_height="44dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:cardCornerRadius="12dp">

        <!-- 앨범아트 -->
        <ImageView
            android:id="@+id/artwork_image"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop">
        </ImageView>
    </com.google.android.material.card.MaterialCardView>

    <!-- 막대 2개 컨테이너 -->
    <LinearLayout
        android:id="@+id/bar_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintStart_toEndOf="@id/artwork_card"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/artwork_card"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginStart="8dp">

        <!-- 위: 전체 누적 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:orientation="horizontal">

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/bar_total"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                style="@style/Widget.Material3.LinearProgressIndicator"
                android:progress="0"
                android:max="100"
                app:trackThickness="12dp"
                app:trackCornerRadius="8dp"
                android:layout_marginEnd="4dp"
                />

            <TextView
                android:id="@+id/label_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:text="45"
                android:paddingStart="6dp"
                android:paddingEnd="2dp"
                android:layout_marginTop="-2dp"/>
        </LinearLayout>

        <!-- 아래: 최근 1개월 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:orientation="horizontal">

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/bar_recent"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                style="@style/Widget.Material3.LinearProgressIndicator"
                android:progress="0"
                android:max="100"
                app:trackThickness="12dp"
                app:trackCornerRadius="8dp"
                android:layout_marginEnd="4dp"
                />

            <TextView
                android:id="@+id/label_recent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:text="33"
                android:layout_gravity="end|center_vertical"
                android:paddingStart="6dp"
                android:paddingEnd="2dp"
                android:layout_marginTop="-2dp"/>
        </LinearLayout>
    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>
