<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:padding="8dp"
    android:clipChildren="false"
    android:clipToPadding="false" >

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/combined_artworks_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:cardPreventCornerOverlap="false"
        app:cardUseCompatPadding="false"
        android:background="@android:color/transparent">

        <ImageView
            android:id="@+id/artwork_images"
            android:layout_width="@dimen/artwork_size_in_favorites_list"
            android:layout_height="@dimen/artwork_size_in_favorites_list"
            android:scaleType="centerCrop" />
    </com.google.android.material.card.MaterialCardView>

    <!-- 텍스트 정보 (제목, 아티스트) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/playlist_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apink 노래 모음"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:layout_marginEnd="4dp"
            android:ellipsize="end"
            android:visibility="visible"/>
        <TextView
            android:id="@+id/track_count_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="16곡"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#666666"
            android:maxLines="1"
            android:ellipsize="end" />
        <TextView
            android:id="@+id/playlist_play_time_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="52분 27초"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#666666"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>
    <ImageButton
        android:id="@+id/playlist_shuffle_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_round_shuffle"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_gravity="center_vertical"
        app:layout_constraintTop_toTopOf="@id/artistTextView"
        app:layout_constraintBottom_toBottomOf="@id/artistTextView"
        app:layout_constraintEnd_toEndOf="@id/parent"
        android:layout_marginBottom="4dp"
        android:padding="8dp" />
    <ImageButton
        android:id="@+id/playlist_play_button"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_gravity="center_vertical"
        android:layout_marginBottom="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:src="@drawable/ic_play_arrow"
        app:layout_constraintBottom_toBottomOf="@id/artistTextView"
        app:layout_constraintEnd_toEndOf="@id/parent"
        app:layout_constraintTop_toTopOf="@id/artistTextView" />

    <ImageButton
        android:id="@+id/hamburger_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/round_more_vertical"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_gravity="center_vertical"
        app:layout_constraintTop_toTopOf="@id/artistTextView"
        app:layout_constraintBottom_toBottomOf="@id/artistTextView"
        app:layout_constraintEnd_toEndOf="@id/parent"
        android:layout_marginBottom="4dp"
        android:padding="8dp" />
</LinearLayout>