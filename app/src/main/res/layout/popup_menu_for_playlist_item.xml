<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:padding="2dp"
    app:cardCornerRadius="10dp"
    app:cardBackgroundColor="#2B2B2B">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/add_to_temporary_playlist_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="6dp"
                android:text="임시 재생목록에 추가"
                android:textColor="@android:color/white"
                android:textSize="@dimen/text_size_xsmall" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#555555" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/music_shuffle_here_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="6dp"
                android:text="이 곡을 첫곡으로 고정하고 셔플"
                android:textColor="@android:color/white"
                android:textSize="@dimen/text_size_xsmall" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#555555" />
        </LinearLayout>




        <LinearLayout
            android:id="@+id/create_new_playlist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="6dp"
                android:text="플레이리스트 새로 만들기"
                android:textColor="@android:color/white"
                android:textSize="@dimen/text_size_xsmall" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#555555" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/show_playlists_for_track"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="6dp"
                android:text="이 곡이 포함된 플레이리스트 보기"
                android:textColor="@android:color/white"
                android:textSize="@dimen/text_size_xsmall" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#555555" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/remove_from_playlist_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">
            <TextView
                android:id="@+id/remove_from_playlist_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="6dp"
                android:text="[playlist name] 에서 제거"
                android:textColor="@android:color/white"
                android:textSize="@dimen/text_size_xsmall" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#555555" />
        </LinearLayout>


    </LinearLayout>



</com.google.android.material.card.MaterialCardView>


