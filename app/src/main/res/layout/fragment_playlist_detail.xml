<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/foreground_fragment_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/background_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="@dimen/navigation_bar_margin">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="4dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp">

            <!-- 고정 상단 영역 -->
            <FrameLayout
                android:id="@+id/fixed_top_frame"
                android:layout_width="match_parent"
                android:layout_height="33dp"
                android:background="@android:color/transparent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <EditText
                    android:id="@+id/search_keyword"
                    android:layout_width="120dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginLeft="9dp"
                    android:textSize="16sp"
                    android:inputType="text"
                    android:imeOptions="actionDone"
                    android:drawableStart="@drawable/ic_search_button_18dp"
                    android:background="@drawable/search_edittext_bg" />

                <ImageButton
                    android:id="@+id/previous_keyword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="135dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_north_16dp"
                    android:background="@android:color/transparent" />

                <ImageButton
                    android:id="@+id/next_keyword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="160dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_south_16dp"
                    android:background="@android:color/transparent" />

                <TextView
                    android:id="@+id/keyword_searched_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/0"
                    android:textSize="14sp"
                    android:layout_marginLeft="205dp"
                    android:layout_marginTop="6dp" />

                <LinearLayout
                    android:id="@+id/count_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|top"
                    android:layout_marginTop="3dp"
                    android:layout_marginRight="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/cancel_selection_mode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="취소"
                        android:textSize="16sp"
                        android:textColor="#666666"
                        android:visibility="invisible"
                        android:layout_marginRight="8dp" />

                    <TextView
                        android:id="@+id/select_favorites"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="선택"
                        android:textSize="16sp"
                        android:textColor="#666666"
                        android:visibility="visible"
                        android:layout_marginRight="10dp" />
                    <TextView
                        android:id="@+id/edit_location_favorites"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="편집"
                        android:textSize="16sp"
                        android:textColor="#666666"
                        android:visibility="visible"
                        android:layout_marginRight="10dp" />
                </LinearLayout>

            </FrameLayout>


            <androidx.core.widget.NestedScrollView
                android:id="@+id/scroll_area"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/fixed_top_frame">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    app:layout_constraintTop_toBottomOf="@id/fixed_top_frame"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="24dp"
                        android:elevation="0dp"
                        app:strokeWidth="0.5dp"
                        app:strokeColor="#8F8F8F"

                        android:clipToOutline="false"
                        android:clipChildren="false">
                        <ImageView
                            android:id="@+id/combined_artworks"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                        </ImageView>

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/playlist_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="playlist name"
                        android:layout_marginTop="8dp"
                        android:textSize="@dimen/text_size_large"
                        android:textStyle="bold">
                    </TextView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_margin="4dp">
                        <TextView
                            android:id="@+id/playlist_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="11곡"
                            android:textStyle="bold"
                            android:textSize="@dimen/text_size_xxsmall">
                        </TextView>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" · "
                            android:textStyle="bold"
                            android:textSize="@dimen/text_size_xxsmall">
                        </TextView>
                        <TextView
                            android:id="@+id/playlist_total_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="54분 1초"
                            android:textStyle="bold"
                            android:textSize="@dimen/text_size_xxsmall">
                        </TextView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_margin="8dp">
                       <ImageButton
                           android:id="@+id/music_shuffle"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:src="@drawable/ic_round_shuffle"
                           android:background="@android:color/transparent"
                           android:layout_marginStart="24dp"
                           android:layout_marginEnd="24dp">
                       </ImageButton>
                        <ImageButton
                            android:id="@+id/music_play"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_play_arrow"
                            android:background="@android:color/transparent"
                            android:layout_marginStart="24dp"
                            android:layout_marginEnd="24dp"
                            android:scaleY="1.2"
                            android:scaleX="1.2">
                        </ImageButton>
                        <ImageButton
                            android:id="@+id/rename"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_round_edit"
                            android:background="@android:color/transparent"
                            android:layout_marginStart="24dp"
                            android:layout_marginEnd="24dp">
                        </ImageButton>
                    </LinearLayout>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/track_recycler_view"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="5"
                        android:layout_marginLeft="8dp"
                        android:layout_marginRight="8dp"
                        android:layout_marginTop="18dp"
                        android:visibility="visible" />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="200dp">
                    </View>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>
</FrameLayout>