<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/transparent">

    <LinearLayout
        android:layout_width="@dimen/custom_dialog_width"
        android:layout_height="wrap_content"
        android:background="@color/basic"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 아이콘 + 제목 -->

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="title"
            android:layout_gravity="center"
            android:textColor="@color/textPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />


        <!-- 설명 -->
        <TextView
            android:id="@+id/subtext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="subtext"
            android:textColor="@color/textPrimary"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/delete_metadata_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="metadata 만 삭제하기"
            android:textColor="@color/textPrimary"
            android:textSize="14sp"/>

        <!-- 버튼 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- 취소 버튼 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:layout_gravity="center"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/basic"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <TextView
                    android:id="@+id/cancel_button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="취소"
                    android:textColor="@color/cancel_text_color"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 확인 버튼 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_gravity="center"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/basic"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <TextView
                    android:id="@+id/confirm_button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="확인"
                    android:textColor="#FF3C3C"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
