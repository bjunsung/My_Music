<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:padding="8dp">

    <!-- 체크박스 (필터 모드에서만 표시) -->
    <CheckBox
        android:id="@+id/select_checkbox"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="8dp"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- 앨범 이미지 -->
    <ImageView
        android:id="@+id/imageView"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginEnd="12dp"
        android:scaleType="centerCrop" />

    <!-- 텍스트 정보 (제목, 아티스트) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/artistNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apink"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:layout_marginEnd="4dp"
            android:ellipsize="end" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="followers: "
                android:textSize="12sp"
                android:textColor="#666666"
                android:maxLines="1"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/followersTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1,303,867"
                android:textSize="12sp"
                android:textColor="#666666"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/debut_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="데뷔일: "
                android:textSize="12sp"
                android:textColor="#666666"
                android:maxLines="1"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/debut_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2011-04-19"
                android:textSize="12sp"
                android:textColor="#666666"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="추가한 날짜: "
                android:textSize="12sp"
                android:textColor="#666666"
                android:maxLines="1"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/addedDateTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2025-06-22"
                android:textSize="12sp"
                android:textColor="#666666"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

    </LinearLayout>

    <ImageButton
        android:id="@+id/deleteButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_delete_button"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_gravity="center_vertical"
        app:layout_constraintTop_toTopOf="@id/artistTextView"
        app:layout_constraintBottom_toBottomOf="@id/artistTextView"
        app:layout_constraintEnd_toEndOf="@id/parent"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="4dp"
        android:padding="4dp"/>
    <ImageButton
        android:id="@+id/add_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_rounded_add_photo_alternate"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_gravity="center_vertical"
        app:layout_constraintTop_toTopOf="@id/artistTextView"
        app:layout_constraintBottom_toBottomOf="@id/artistTextView"
        app:layout_constraintEnd_toEndOf="@id/parent"
        android:layout_marginBottom="4dp"
        android:padding="4dp"
        android:layout_marginEnd="4dp"/>
    <ImageButton
        android:id="@+id/image_album_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_rounded_photo_library"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_gravity="center_vertical"
        app:layout_constraintTop_toTopOf="@id/artistTextView"
        app:layout_constraintBottom_toBottomOf="@id/artistTextView"
        app:layout_constraintEnd_toEndOf="@id/parent"
        android:layout_marginBottom="4dp"
        android:padding="4dp"
        android:layout_marginEnd="4dp"
        android:visibility="gone"/>
</LinearLayout>