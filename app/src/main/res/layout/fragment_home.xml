<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.home.HomeFragment">

    <!-- 고정 검색창 -->
    <TextView
        android:id="@+id/search_bar"
        android:layout_width="400dp"
        android:layout_height="40dp"
        android:paddingTop="4dp"
        android:paddingLeft="6dp"
        android:text="노래 또는 아티스트를 검색하세요"
        android:layout_marginTop="18dp"
        android:layout_marginLeft="24dp"
        android:layout_marginRight="24dp"
        android:textSize="18sp"
        android:gravity="center"
        android:drawableStart="@drawable/ic_search_button_18dp"
        android:background="@drawable/search_edittext_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 스크롤 영역 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/content_scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/search_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:id="@+id/on_this_days_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <!-- 오늘 발매 FrameLayout -->
                <FrameLayout
                    android:id="@+id/on_this_days_releases_frame"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:clipChildren="false"
                        android:clipToOutline="false">

                        <TextView
                            android:id="@+id/year_diff"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="n 년전 오늘"
                            android:textSize="@dimen/text_size_basic"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary" />

                        <TextView
                            android:id="@+id/title_and_artist"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:maxLines="2"
                            android:textSize="@dimen/text_size_small"
                            android:textColor="@color/textPrimary" />

                        <androidx.viewpager2.widget.ViewPager2
                            android:id="@+id/on_this_days_releases_view_pager"
                            android:background="@android:color/transparent"
                            android:layout_width="300dp"
                            android:layout_height="300dp"
                            android:clipChildren="false"
                            android:clipToOutline="false" />
                    </LinearLayout>
                </FrameLayout>

                <!-- 이번 달 발매 FrameLayout -->
                <LinearLayout
                    android:id="@+id/see_on_this_month_releases_frame"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="36dp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:orientation="vertical"
                    android:clipChildren="false"
                    android:clipToOutline="false"
                    android:background="@android:color/transparent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/see_on_this_month_releases_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JANUARY 발매"
                            android:textSize="@dimen/text_size_basic"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary" />

                        <TextView
                            android:id="@+id/on_this_month_releases_count_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="(  곡)"
                            android:textSize="@dimen/text_size_xsmall"
                            android:layout_marginStart="4dp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary" />

                        <ImageButton
                            android:id="@+id/see_on_this_month_releases"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="1.5dp"
                            android:layout_marginTop="2.5dp"
                            android:background="@android:color/transparent"
                            android:scaleX="1.2"
                            android:scaleY="1.2"
                            android:src="@drawable/ic_arrow_drop_down" />
                    </LinearLayout>

                    <androidx.viewpager2.widget.ViewPager2
                        android:layout_marginTop="12dp"
                        android:id="@+id/on_this_month_releases_view_pager"
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:clipChildren="false"
                        android:clipToOutline="false" />
                </LinearLayout>
            </LinearLayout>


            <LinearLayout
                android:id="@+id/top_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/on_this_days_layout"
                app:layout_constraintStart_toStartOf="parent">

                <!-- 오늘 발매 FrameLayout -->
                <FrameLayout
                    android:layout_width="300dp"
                    android:layout_height="300dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:clipChildren="false"
                        android:clipToOutline="false">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="최근 한달 최다 재생"
                            android:textSize="@dimen/text_size_basic"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/hot_now_recycler_view"
                            android:layout_width="300dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">
                        </androidx.recyclerview.widget.RecyclerView>
                    </LinearLayout>
                </FrameLayout>

                <!-- 이번 달 발매 FrameLayout -->
                <LinearLayout
                    android:id="@+id/recently_drop_layout"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:orientation="vertical"
                    android:clipChildren="false"
                    android:clipToOutline="false"
                    android:background="@android:color/transparent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="재생 빈도 감소"
                            android:textSize="@dimen/text_size_basic"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary" />
                        <TextView
                            android:id="@+id/baseline_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="(기준 : 12주 전)"
                            android:textStyle="bold"
                            android:layout_marginStart="10dp"
                            android:layout_gravity="center"></TextView>

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recently_drop_recycler_view"
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:layout_marginTop="8dp">
                    </androidx.recyclerview.widget.RecyclerView>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/play_data_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/top_layout"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="최근 한달 음악 재생 정보"
                        android:textSize="@dimen/text_size_basic"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="16dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="재생횟수: ">
                        </TextView>
                        <TextView
                            android:id="@+id/total_play_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="896회">
                        </TextView>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="재생시간: ">
                        </TextView>
                        <TextView
                            android:id="@+id/total_play_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7시간 48분 17초">
                        </TextView>
                    </LinearLayout>


                </LinearLayout>
            </LinearLayout>



            <View
                android:layout_width="match_parent"
                android:layout_height="120dp"
                app:layout_constraintTop_toBottomOf="@id/top_layout"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
            </View>

        </androidx.constraintlayout.widget.ConstraintLayout>




    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
