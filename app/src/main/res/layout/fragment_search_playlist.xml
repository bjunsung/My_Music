<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/foreground_fragment_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/background_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="@dimen/navigation_bar_margin">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="8dp">

            <!-- 고정 상단 영역 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="33dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:background="@android:color/transparent"
                />


            <ImageButton
                android:id="@+id/filter_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:layout_marginLeft="16dp"
                android:src="@drawable/ic_filter_button"
                android:background="@android:color/transparent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                />

            <ImageButton
                android:id="@+id/in_order_button_drop_down"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="24dp"
                android:layout_marginTop="3dp"
                android:src="@drawable/ic_arrow_drop_down"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/filter_button"
                android:layout_marginStart="14dp"
                android:visibility="gone"
                />

            <ImageButton
                android:id="@+id/in_order_button_drop_up"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="23dp"
                android:layout_marginTop="3dp"
                android:src="@drawable/ic_arrow_drop_up_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/filter_button"
                android:layout_marginStart="14dp"
                />

            <EditText
                android:id="@+id/search_keyword"
                android:layout_width="120dp"
                android:layout_marginTop="4dp"
                android:layout_marginLeft="9dp"
                android:layout_height="24dp"
                android:textSize="16sp"
                android:inputType="text"
                android:imeOptions="actionDone"
                android:drawableStart="@drawable/ic_search_button_18dp"
                android:background="@drawable/search_edittext_bg"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/in_order_button_drop_up"
                />

            <ImageButton
                android:id="@+id/previous_keyword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_north_16dp"
                android:background="@android:color/transparent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/search_keyword" />


            <ImageButton
                android:id="@+id/next_keyword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="-6dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_south_16dp"
                android:background="@android:color/transparent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/previous_keyword" />

            <TextView
                android:id="@+id/keyword_searched_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                android:text="0/0"
                android:textSize="14sp"
                android:layout_marginLeft="2dp"
                android:layout_marginTop="6dp"
                app:layout_constraintStart_toEndOf="@+id/next_keyword" />



            <LinearLayout
                android:id="@+id/count_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="3dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/cancel_selection_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="취소"
                    android:textSize="16sp"
                    android:textColor="#666666"
                    android:visibility="visible"
                    android:layout_marginRight="8dp" />

                <TextView
                    android:id="@+id/add_selected_favorites"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="추가"
                    android:textSize="16sp"
                    android:textColor="#666666"
                    android:visibility="visible"
                    android:layout_marginRight="10dp" />
                <TextView
                    android:id="@+id/favorites_loaded_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#"
                    android:textSize="16sp"
                    android:textColor="#666666"
                    android:layout_marginRight="8dp" />

                <TextView
                    android:id="@+id/element_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Songs"
                    android:textSize="16sp"
                    android:textColor="#666666"
                    android:layout_marginRight="10dp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/cancel_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="16dp"
                android:visibility="invisible"/>

            <TextView
                android:id="@+id/empty_favorite_song"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Favorites List 가 비어있습니다. 좋아하는 노래를 추가하세요."
                android:textSize="16sp"
                android:layout_marginLeft="10dp"
                app:layout_constraintTop_toBottomOf="@+id/filter_button"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:visibility="visible" />



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintTop_toBottomOf="@id/filter_button"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:orientation="vertical">
                <!-- 리사이클러뷰: 기본 visible -->
                <TextView
                    android:id="@+id/track_recycler_view_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Favorites"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold">
                </TextView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/track_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="5"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="8dp"
                    android:layout_marginTop="8dp"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/track_related_recycler_view_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Related"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold">
                </TextView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/track_related_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="2"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="8dp"
                    android:layout_marginTop="8dp"
                    android:visibility="visible"
                    />
            </LinearLayout>




        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>
</FrameLayout>
