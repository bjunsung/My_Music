<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/transparent">

    <LinearLayout
        android:layout_width="@dimen/custom_dialog_width"
        android:layout_height="wrap_content"
        android:background="@color/background_basic2"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 제목 -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="날짜선택 (년)"
            android:textColor="@color/textPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- 설명 -->
        <TextView
            android:id="@+id/subtext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="원하는 연도를 선택하세요."
            android:textColor="@color/textPrimary"
            android:textSize="14sp" />

        <!-- 연도 선택 NumberPicker -->
        <NumberPicker
            android:id="@+id/npYear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <!-- 버튼 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- 취소 버튼 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cancel_button_card"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/background_basic2"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <TextView
                    android:id="@+id/cancel_button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="취소"
                    android:textColor="@color/cancel_text_color"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 확인 버튼 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/confirm_button_card"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/background_basic2"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <TextView
                    android:id="@+id/confirm_button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="확인"
                    android:textColor="#FF3C3C"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
