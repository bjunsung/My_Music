<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.search.SearchFragment">


    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/favorite_option_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginRight="8dp"
        app:layout_constraintStart_toStartOf="parent"
        android:checked="false"
        tools:ignore="UseSwitchCompatOrMaterialXml" />


    <ImageButton
        android:id="@+id/filter_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="28dp"
        android:src="@drawable/baseline_backspace_24"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@+id/favorite_option_switch"
        android:layout_marginEnd="16dp"/>


    <TextView
        android:id="@+id/favorites_loaded_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="#"
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginTop="28dp"
        android:layout_marginRight="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/element_count"
        />

    <TextView
        android:id="@+id/element_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="elements"
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginTop="28dp"
        android:layout_marginRight="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <TextView
        android:id="@+id/empty_favorite_song"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Favorites List 가 비어있습니다. 좋아하는 노래를 추가하세요."
        android:textSize="16sp"
        android:layout_marginLeft="10dp"
        app:layout_constraintTop_toBottomOf="@+id/filter_button"
        app:layout_constraintStart_toStartOf="parent"
        android:visibility="visible"
        />

    <TextView
        android:id="@+id/empty_favorite_artist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Favorites List 가 비어있습니다. 좋아하는 아티스트를 추가하세요."
        android:textSize="16sp"
        android:layout_marginLeft="10dp"
        app:layout_constraintTop_toBottomOf="@+id/filter_button"
        app:layout_constraintStart_toStartOf="parent"
        android:visibility="visible"
        />


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/result_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:paddingBottom="@dimen/navigation_bar_margin"
        app:layout_constraintTop_toBottomOf="@id/filter_button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <include layout="@layout/include_webview_hidden" />


    <TextView
        android:id="@+id/baselineLeft"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="___기준선___"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/scroll_area"
        app:layout_constraintDimensionRatio="4:5"
        app:layout_constraintHorizontal_weight="6"/>

    <TextView
        android:id="@+id/baselineRight"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="___기준선___"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/scroll_area"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="4:5"
        app:layout_constraintHorizontal_weight="1"/>


    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/scroll_area"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/baselineLeft"
        app:layout_constraintEnd_toStartOf="@id/baselineRight"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="60dp"
        android:paddingRight="80dp"
        android:scrollbars="none"
        app:layout_constraintHorizontal_weight="5">

        <LinearLayout
            android:id="@+id/metadata_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <TextView
                android:id="@+id/metadata_lyrics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="슬퍼하지마 No No No
\n혼자가 아냐 No No No
\n언제나나나 내게 항상 빛이 돼 준 그대
\n내 손을 잡아요 이제 지금 다가와 기대
\n언제나 힘이 돼 줄게
\n
\n내가 힘이 들 때 내게 다가온 그대
\n살며시 내게로 와 입맞춰 준 그대
\n마치 마법처럼 날 감싸준
